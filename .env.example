PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wallet_tracker
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars
JWT_ACCESS_TOKEN_TTL_SECONDS=604800
LOG_LEVEL=info
ENABLE_PUSH_NOTIFICATIONS=false
# Webhook-first mode: keep false in normal real-time operation.
# Set true only for local polling tests or fallback/debug runs.
ENABLE_ETHEREUM_TRACKER=false
ENABLE_PORTFOLIO_SNAPSHOT_JOB=true
PORTFOLIO_SNAPSHOT_INTERVAL_MS=3600000
FIREBASE_DRY_RUN=true
FIREBASE_SERVICE_ACCOUNT_JSON=
FIREBASE_ANDROID_NOTIFICATION_CHANNEL_ID=fcm_fallback_notification_channel
ALCHEMY_ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
DEBANK_ACCESS_KEY=
ZERION_API_KEY=
ETHEREUM_CONFIRMATIONS=6
ETHEREUM_BATCH_SIZE=250
ETHEREUM_POLL_INTERVAL_MS=15000
ETHEREUM_START_BLOCK=0
ETHEREUM_RPC_REQUEST_DELAY_MS=1000
ETHEREUM_RPC_MAX_RETRIES=5
ETHEREUM_RPC_BACKOFF_BASE_MS=1000
ETHEREUM_RESET_SYNC_CURSOR=false
ETHEREUM_TRACE_FROM_ADDRESS=
ETHEREUM_TRACE_TO_ADDRESS=
ETHEREUM_TRACE_TX_HASH=
